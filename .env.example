STAYAPI_API_KEY=
GMAIL_APP_PASSWORD=
# Optional — from DevTools dx-customer/auth request body (if Hilton blocks page fetch)
HILTON_APP_ID=
# Optional — short-lived Bearer from DevTools Authorization header (for testing)
HILTON_ACCESS_TOKEN=
HILTON_APP_VERSION=dx-res-ui:888446
# Optional — session UUID from getShopAvail variables (expires; omit to use Playwright)
HILTON_CACHE_ID=
# Guest country code sent in GraphQL (default IL)
HILTON_GUEST_COUNTRY=IL
